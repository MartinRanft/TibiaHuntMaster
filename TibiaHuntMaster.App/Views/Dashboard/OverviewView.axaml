<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TibiaHuntMaster.App.ViewModels.Dashboard"
             xmlns:conv="using:TibiaHuntMaster.App.Converters"
             xmlns:anim="https://github.com/whistyun/AnimatedImage.Avalonia"
             xmlns:components="using:TibiaHuntMaster.App.Components"
             xmlns:behaviors="using:TibiaHuntMaster.App.Behaviors"
             xmlns:loc="using:TibiaHuntMaster.App.Extensions"
             x:Name="Root"
             x:Class="TibiaHuntMaster.App.Views.Dashboard.OverviewView"
             x:DataType="vm:OverviewViewModel">

    <UserControl.Resources>
        <conv:VocationToImageConverter x:Key="VocConverter" />
        <conv:BalanceColorConverter x:Key="BalanceColorConverter" />
        <conv:TibiaCurrencyConverter x:Key="TibiaCurrencyConverter" />
        <conv:NullableIntConverter x:Key="NullableIntConverter" />

        <!-- FIX: x:DataType hinzugefügt -->
        <DataTemplate x:Key="GoalItemTemplate" DataType="vm:GoalItemViewModel" x:CompileBindings="False">
            <Border Background="{DynamicResource BrushSurface}" CornerRadius="{StaticResource RadiusMedium}"
                    Padding="12" Margin="0,0,0,10" BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1" Classes="FadeIn">
                <Grid RowDefinitions="Auto, Auto">
                    <!-- Top: Icon, Title, Buttons -->
                    <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto, Auto">
                        <TextBlock Text="{Binding Icon}" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Grid.Column="1" Text="{Binding Entity.Title}" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   VerticalAlignment="Center" />

                        <!-- History Button -->
                        <Button Grid.Column="2" Content="📜" ToolTip.Tip="{loc:Localize Overview_ShowHuntsInHistory}"
                                Command="{Binding $parent[UserControl].DataContext.NavigateToHistoryCommand}"
                                CommandParameter="{Binding}"
                                Classes="IconButton" Foreground="{DynamicResource BrushInfo}" Padding="8,0"
                                FontSize="14"
                                Margin="0,0,5,0" />

                        <!-- Add Progress -->
                        <Button Grid.Column="3" Content="➕" ToolTip.Tip="{loc:Localize Overview_AddManualProgress}"
                                Command="{Binding $parent[UserControl].DataContext.OpenAddProgressDialogCommand}"
                                CommandParameter="{Binding}"
                                Classes="IconButton" Foreground="{DynamicResource BrushSuccess}" Padding="8,0"
                                FontSize="14" />

                        <!-- Edit -->
                        <Button Grid.Column="4" Content="✎" ToolTip.Tip="{loc:Localize Overview_EditGoal}"
                                Command="{Binding $parent[UserControl].DataContext.OpenEditDialogCommand}"
                                CommandParameter="{Binding}"
                                Classes="IconButton" Foreground="{DynamicResource BrushTextSecondary}" Padding="8,0"
                                FontSize="14" />

                        <!-- Delete -->
                        <Button Grid.Column="5" Content="×" ToolTip.Tip="{loc:Localize Overview_DeleteGoal}"
                                Command="{Binding $parent[UserControl].DataContext.DeleteGoalCommand}"
                                CommandParameter="{Binding}"
                                Classes="IconButton" Foreground="{DynamicResource BrushTextDisabled}" Padding="8,0"
                                FontSize="18" />
                    </Grid>

                    <!-- Bottom: Progress Bar & Values -->
                    <StackPanel Grid.Row="1" Margin="0,10,0,0">
                        <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,5">
                            <TextBlock Text="{Binding PercentText}" Foreground="{Binding ProgressColor}"
                                       FontWeight="Bold" FontSize="12" />
                            <TextBlock Grid.Column="1" Text="{Binding ProgressText}"
                                       Foreground="{DynamicResource BrushTextSecondary}" FontSize="11" />
                        </Grid>
                        <ProgressBar Value="{Binding Percentage}" Minimum="0" Maximum="100" Height="6"
                                     Foreground="{Binding ProgressColor}" Background="{DynamicResource BrushBorder}"
                                     CornerRadius="3" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <!-- Haupt-Layout -->
        <Grid RowDefinitions="Auto, Auto, *">
            <!-- 1. HEADER -->
            <Border Background="{DynamicResource BrushSurfaceElevated}" CornerRadius="8,8,0,0" Padding="20"
                    Margin="0,0,0,0" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="Auto, *">
                    <Border Width="80" Height="80" CornerRadius="40" ClipToBounds="True"
                            Background="{DynamicResource BrushBorder}">
                        <Image Source="{Binding Character.Vocation, Converter={StaticResource VocConverter}}"
                               Stretch="UniformToFill" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="{Binding Character.Name}" FontSize="32" FontWeight="Light"
                                       Foreground="{DynamicResource BrushTextPrimary}" />
                            <Border Background="{DynamicResource BrushSurfaceElevated}"
                                    BorderBrush="{DynamicResource BrushAccentGold}"
                                    BorderThickness="2"
                                    CornerRadius="4" Padding="8,2"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding Character.Level, StringFormat='Lvl {0}'}"
                                           Foreground="{DynamicResource BrushTextPrimary}" FontWeight="Bold" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding Character.World}" Foreground="{DynamicResource BrushTextSecondary}"
                                   FontSize="14" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2. KPI TILES -->
            <Grid Grid.Row="1" ColumnDefinitions="*, 1, *, 1, *" Margin="0,0,0,0">
                <Border Grid.Column="0" Background="{DynamicResource BrushSurfaceElevated}" CornerRadius="0"
                        Padding="20" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="{loc:Localize Overview_TotalProfit}" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushTextTertiary}"
                                   Margin="0,0,0,5" />
                        <TextBlock Text="{Binding TotalBalance, Converter={StaticResource TibiaCurrencyConverter}}"
                                   FontSize="28" FontWeight="SemiBold"
                                   Foreground="{Binding TotalBalance, Converter={StaticResource BalanceColorConverter}}" />
                    </StackPanel>
                </Border>
                <Rectangle Grid.Column="1" Fill="{DynamicResource BrushBorder}" />
                <Border Grid.Column="2" Background="{DynamicResource BrushSurfaceElevated}" Padding="20"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="{loc:Localize Overview_AvgXpPerHour}" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushTextTertiary}"
                                   Margin="0,0,0,5" />
                        <TextBlock Text="{Binding AvgXpPerHour, Converter={StaticResource TibiaCurrencyConverter}}"
                                   FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource BrushInfo}" />
                    </StackPanel>
                </Border>
                <Rectangle Grid.Column="3" Fill="{DynamicResource BrushBorder}" />
                <Border Grid.Column="4" Background="{DynamicResource BrushSurfaceElevated}" CornerRadius="0,0,0,0"
                        Padding="20"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="{loc:Localize Overview_TrackedTime}" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource BrushTextTertiary}"
                                   Margin="0,0,0,5" />
                        <TextBlock Text="{Binding TotalPlaytime, StringFormat='{}{0:%h}h {0:%m}m'}" FontSize="28"
                                   FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 3. SPLIT CONTENT -->
            <Grid Grid.Row="2" ColumnDefinitions="*, 20, *">

                <!-- LINKS: GOALS SYSTEM -->
                <Border Grid.Column="0" Background="{DynamicResource BrushSurfaceElevated}" CornerRadius="0,0,0,8"
                        Padding="20">
                    <Grid RowDefinitions="Auto, *, Auto">
                        <!-- Header -->
                        <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,15">
                            <TextBlock Text="{loc:Localize Overview_ActiveGoals}" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextPrimary}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1" Command="{Binding OpenAddGoalCommand}"
                                    Background="Transparent" BorderThickness="1"
                                    BorderBrush="{DynamicResource BrushBorderLight}" CornerRadius="4">
                                <TextBlock Text="+" FontWeight="Bold" Foreground="{DynamicResource BrushAccentGold}" />
                            </Button>
                        </Grid>

                        <!-- List ACTIVE -->
                        <ScrollViewer Grid.Row="1">
                            <ItemsControl ItemsSource="{Binding ActiveGoals}"
                                          ItemTemplate="{StaticResource GoalItemTemplate}" />
                        </ScrollViewer>

                        <!-- Empty State -->
                        <components:EmptyState Grid.Row="2"
                                               Message="{loc:Localize Overview_NoActiveGoalsMessage}"
                                               Icon="🎯"
                                               IsVisible="{Binding !ActiveGoals.Count}"
                                               Margin="0,20,0,20" />

                    </Grid>
                </Border>

                <!-- RECHTS: DEATHS -->
                <Border Grid.Column="2" Background="{DynamicResource BrushSurfaceElevated}" CornerRadius="0,0,8,0"
                        Padding="20">
                    <StackPanel Spacing="15">
                        <TextBlock Text="{loc:Localize Overview_RecentDeaths}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextPrimary}" />
                        <TextBlock Text="{loc:Localize Overview_NoDeaths}" Foreground="{DynamicResource BrushTextMuted}"
                                   FontStyle="Italic"
                                   IsVisible="{Binding !RecentDeaths.Count}" />

                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding RecentDeaths}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BrushSurface}"
                                                CornerRadius="{StaticResource RadiusMedium}" Padding="10" Width="130"
                                                Margin="0,0,10,10" BorderBrush="{DynamicResource BrushBorder}"
                                                BorderThickness="1">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="{Binding TimeAgo}" FontSize="10"
                                                           Foreground="{DynamicResource BrushTextTertiary}"
                                                           HorizontalAlignment="Right" />
                                                <Border Height="50" Width="50"
                                                        Background="{DynamicResource BrushBackground}" CornerRadius="4"
                                                        ClipToBounds="True" HorizontalAlignment="Center">
                                                    <Image anim:ImageBehavior.AnimatedSource="{Binding ImageSource}"
                                                           Stretch="Uniform" />
                                                </Border>
                                                <TextBlock Text="{Binding KillerName}"
                                                           Foreground="{DynamicResource BrushError}"
                                                           FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding KillerName}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ADD GOAL OVERLAY (Unverändert) -->
        <Grid Grid.RowSpan="3" Background="{DynamicResource BrushOverlay}" IsVisible="{Binding IsDialogVisible}">
            <Border Background="{DynamicResource BrushSurfaceElevated}" BorderBrush="{DynamicResource BrushBorderLight}"
                    BorderThickness="1" CornerRadius="8" Width="400"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25">
                <StackPanel Spacing="15">
                    <TextBlock Text="{loc:Localize Goal_AddNewGoal}" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               IsVisible="{Binding IsCreateMode}" />
                    <TextBlock Text="{loc:Localize Goal_EditGoal}" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               IsVisible="{Binding IsEditMode}" />
                    <TextBlock Text="{loc:Localize Goal_AddManualProgress}" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               IsVisible="{Binding IsProgressMode}" />

                    <!-- CREATE -->
                    <StackPanel IsVisible="{Binding IsCreateMode}" Spacing="10">
                        <StackPanel Spacing="5">
                            <TextBlock Text="{loc:Localize Goal_Title}" Foreground="{DynamicResource BrushTextTertiary}" FontSize="12" />
                            <TextBox Text="{Binding GoalTitleInput}" PlaceholderText="{loc:Localize Goal_TitlePlaceholder}" />
                        </StackPanel>
                        <StackPanel Spacing="5">
                            <TextBlock Text="{loc:Localize Goal_Type}" Foreground="{DynamicResource BrushTextTertiary}" FontSize="12" />
                            <ComboBox ItemsSource="{Binding GoalTypeOptions}"
                                      SelectedIndex="{Binding NewGoalTypeIndex}"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <StackPanel Spacing="5">
                            <TextBlock Text="{loc:Localize Goal_TargetValue}" Foreground="{DynamicResource BrushTextTertiary}"
                                       FontSize="12" />
                            <TextBox Text="{Binding GoalTargetInput, Converter={StaticResource NullableIntConverter}}"
                                     PlaceholderText="{loc:Localize Goal_TargetPlaceholder}"
                                     behaviors:NumericTextBoxBehavior.DigitsOnly="True" />
                        </StackPanel>
                        <StackPanel Spacing="5" IsVisible="{Binding IsLevelGoalSelected}">
                            <TextBlock Text="{loc:Localize Goal_BaseLevel}" Foreground="{DynamicResource BrushTextTertiary}"
                                       FontSize="12" />
                            <TextBox Text="{Binding GoalBaseLevelInput, Converter={StaticResource NullableIntConverter}}"
                                     PlaceholderText="{loc:Localize Goal_BaseLevelPlaceholder}"
                                     behaviors:NumericTextBoxBehavior.DigitsOnly="True" />
                            <TextBlock Text="{loc:Localize Goal_BaseLevelInfo}" FontSize="10"
                                       Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Spacing="5">
                            <TextBlock Text="{loc:Localize Goal_StartTracking}" Foreground="{DynamicResource BrushTextTertiary}"
                                       FontSize="12" />
                            <DatePicker SelectedDate="{Binding GoalStartDate}" />
                            <TextBlock Text="{loc:Localize Goal_StartTrackingInfo}" FontSize="10"
                                       Foreground="{DynamicResource BrushTextSecondary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>

                    <!-- EDIT -->
                    <StackPanel IsVisible="{Binding IsEditMode}" Spacing="10">
                        <StackPanel Spacing="5">
                            <TextBlock Text="{loc:Localize Goal_Title}" Foreground="{DynamicResource BrushTextTertiary}" FontSize="12" />
                            <TextBox Text="{Binding GoalTitleInput}" />
                        </StackPanel>
                        <StackPanel Spacing="5">
                            <TextBlock Text="{Binding EditTargetLabel}" Foreground="{DynamicResource BrushTextTertiary}"
                                       FontSize="12" />
                            <TextBox Text="{Binding GoalTargetInput, Converter={StaticResource NullableIntConverter}}"
                                     behaviors:NumericTextBoxBehavior.DigitsOnly="True" />
                        </StackPanel>
                    </StackPanel>

                    <!-- PROGRESS -->
                    <StackPanel IsVisible="{Binding IsProgressMode}" Spacing="10">
                        <TextBlock Text="{loc:Localize Goal_ManualProgressInfo}"
                                   Foreground="{DynamicResource BrushTextSecondary}" FontSize="12" />
                        <StackPanel Spacing="5">
                            <TextBlock Text="{loc:Localize Goal_Amount}" Foreground="{DynamicResource BrushTextTertiary}" FontSize="12" />
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBox
                                    Text="{Binding ProgressAddInput, Converter={StaticResource NullableIntConverter}}"
                                    PlaceholderText="{loc:Localize Goal_AmountPlaceholder}"
                                    behaviors:NumericTextBoxBehavior.DigitsOnly="True" />
                                <TextBlock Text="{Binding ProgressUnitLabel}" VerticalAlignment="Center"
                                           Margin="10,0,0,0" Foreground="{DynamicResource BrushTextTertiary}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <!-- Validation Error Message -->
                    <components:ErrorMessage Message="{Binding ValidationError}"
                                             Title="{loc:Localize Goal_ValidationError}"
                                             IsVisible="{Binding ValidationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             Margin="0,10,0,0" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
                        <Button Content="{loc:Localize Common_Cancel}" Command="{Binding CloseDialogCommand}" Background="Transparent" />
                        <Button Content="{loc:Localize Common_Save}" Command="{Binding SubmitDialogCommand}" Classes="Primary" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- CELEBRATION OVERLAY -->
        <Grid Grid.RowSpan="3" Background="{DynamicResource BrushOverlay}" IsVisible="{Binding ShowCelebration}">
            <Border Background="{DynamicResource BrushSurfaceElevated}" BorderBrush="{DynamicResource BrushAccentGold}"
                    BorderThickness="2" CornerRadius="12" Padding="40"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="20" HorizontalAlignment="Center">
                    <TextBlock Text="🎉" FontSize="60" HorizontalAlignment="Center" />
                    <TextBlock Text="{loc:Localize Goal_Completed}" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource BrushAccentGold}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding CelebrationTitle}" FontSize="18"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               HorizontalAlignment="Center" />
                    <Button Content="{loc:Localize Goal_Awesome}" Command="{Binding CloseCelebrationCommand}"
                            Classes="Primary"
                            HorizontalAlignment="Center" Margin="0,10,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- LOADING OVERLAY -->
        <components:LoadingOverlay Grid.RowSpan="3" IsVisible="{Binding IsLoading}" />

    </Grid>
</UserControl>
