<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================ -->
    <!-- DESIGN TOKENS - TibiaHuntMaster Design System -->
    <!-- Theme-agnostic tokens (Colors defined in theme files) -->
    <!-- ============================================ -->

    <!-- ============================================ -->
    <!-- SPACING TOKENS -->
    <!-- ============================================ -->

    <x:Double x:Key="SpacingXS">4</x:Double>
    <x:Double x:Key="SpacingSM">8</x:Double>
    <x:Double x:Key="SpacingMD">12</x:Double>
    <x:Double x:Key="SpacingLG">16</x:Double>
    <x:Double x:Key="SpacingXL">20</x:Double>
    <x:Double x:Key="Spacing2XL">30</x:Double>

    <!-- Thickness Resources -->
    <Thickness x:Key="PaddingXS">4</Thickness>
    <Thickness x:Key="PaddingSM">8</Thickness>
    <Thickness x:Key="PaddingMD">12</Thickness>
    <Thickness x:Key="PaddingLG">16</Thickness>
    <Thickness x:Key="PaddingXL">20</Thickness>
    <Thickness x:Key="Padding2XL">30</Thickness>

    <!-- Common Padding Patterns -->
    <Thickness x:Key="PaddingCard">12</Thickness>
    <Thickness x:Key="PaddingPage">30</Thickness>
    <Thickness x:Key="PaddingButton">8,4</Thickness>
    <Thickness x:Key="PaddingButtonLarge">15,10</Thickness>

    <!-- ============================================ -->
    <!-- CORNER RADIUS TOKENS -->
    <!-- ============================================ -->

    <CornerRadius x:Key="RadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">6</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">8</CornerRadius>
    <CornerRadius x:Key="RadiusRound">50</CornerRadius>

    <!-- ============================================ -->
    <!-- TYPOGRAPHY TOKENS -->
    <!-- ============================================ -->

    <!-- Font Sizes -->
    <x:Double x:Key="FontSizeCaption">10</x:Double>
    <x:Double x:Key="FontSizeLabel">11</x:Double>
    <x:Double x:Key="FontSizeBody">14</x:Double>
    <x:Double x:Key="FontSizeBodyLarge">16</x:Double>
    <x:Double x:Key="FontSizeSubtitle">18</x:Double>
    <x:Double x:Key="FontSizeTitle">20</x:Double>
    <x:Double x:Key="FontSizeHeading3">24</x:Double>
    <x:Double x:Key="FontSizeHeading2">28</x:Double>
    <x:Double x:Key="FontSizeHeading1">32</x:Double>

    <!-- Font Weights -->
    <FontWeight x:Key="FontWeightLight">Light</FontWeight>
    <FontWeight x:Key="FontWeightNormal">Normal</FontWeight>
    <FontWeight x:Key="FontWeightMedium">Medium</FontWeight>
    <FontWeight x:Key="FontWeightBold">Bold</FontWeight>

    <!-- ============================================ -->
    <!-- SHADOW TOKENS -->
    <!-- ============================================ -->

    <!-- Elevation Shadows (for future use) -->
    <x:Double x:Key="ElevationLow">2</x:Double>
    <x:Double x:Key="ElevationMedium">4</x:Double>
    <x:Double x:Key="ElevationHigh">8</x:Double>

</ResourceDictionary>
