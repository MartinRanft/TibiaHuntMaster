<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================ -->
    <!-- ANIMATION STYLES - TibiaHuntMaster Design System -->
    <!-- ============================================ -->

    <!-- ============================================ -->
    <!-- FADE IN ANIMATION -->
    <!-- ============================================ -->

    <Style Selector="Border.FadeIn">
        <Style.Animations>
            <Animation Duration="0:0:0.3" FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="StackPanel.FadeIn">
        <Style.Animations>
            <Animation Duration="0:0:0.3" FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Grid.FadeIn">
        <Style.Animations>
            <Animation Duration="0:0:0.3" FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="UserControl.FadeIn">
        <Style.Animations>
            <Animation Duration="0:0:0.3" FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ============================================ -->
    <!-- SLIDE IN ANIMATIONS -->
    <!-- ============================================ -->

    <!-- Slide In from Left -->
    <Style Selector="Border.SlideInLeft">
        <Style.Animations>
            <Animation Duration="0:0:0.4" Easing="CubicEaseOut" FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                    <Setter Property="TranslateTransform.X" Value="-30" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="TranslateTransform.X" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Slide In from Right -->
    <Style Selector="Border.SlideInRight">
        <Style.Animations>
            <Animation Duration="0:0:0.4" Easing="CubicEaseOut" FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                    <Setter Property="TranslateTransform.X" Value="30" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="TranslateTransform.X" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Slide In from Top -->
    <Style Selector="Border.SlideInTop">
        <Style.Animations>
            <Animation Duration="0:0:0.4" Easing="CubicEaseOut" FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                    <Setter Property="TranslateTransform.Y" Value="-30" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="TranslateTransform.Y" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Slide In from Bottom -->
    <Style Selector="Border.SlideInBottom">
        <Style.Animations>
            <Animation Duration="0:0:0.4" Easing="CubicEaseOut" FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                    <Setter Property="TranslateTransform.Y" Value="30" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="TranslateTransform.Y" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ============================================ -->
    <!-- SCALE IN ANIMATION -->
    <!-- ============================================ -->

    <Style Selector="Border.ScaleIn">
        <Style.Animations>
            <Animation Duration="0:0:0.3" Easing="CubicEaseOut" FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                    <Setter Property="ScaleTransform.ScaleX" Value="0.9" />
                    <Setter Property="ScaleTransform.ScaleY" Value="0.9" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="ScaleTransform.ScaleX" Value="1" />
                    <Setter Property="ScaleTransform.ScaleY" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Button.ScaleIn">
        <Style.Animations>
            <Animation Duration="0:0:0.3" Easing="CubicEaseOut" FillMode="Forward">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0" />
                    <Setter Property="ScaleTransform.ScaleX" Value="0.9" />
                    <Setter Property="ScaleTransform.ScaleY" Value="0.9" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="ScaleTransform.ScaleX" Value="1" />
                    <Setter Property="ScaleTransform.ScaleY" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ============================================ -->
    <!-- HOVER ANIMATIONS -->
    <!-- ============================================ -->

    <!-- Hover Scale Up (subtle) -->
    <Style Selector="Button.HoverScale:pointerover">
        <Style.Animations>
            <Animation Duration="0:0:0.15" Easing="CubicEaseOut" FillMode="Forward">
                <KeyFrame Cue="100%">
                    <Setter Property="ScaleTransform.ScaleX" Value="1.05" />
                    <Setter Property="ScaleTransform.ScaleY" Value="1.05" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Button.HoverScale:not(:pointerover)">
        <Style.Animations>
            <Animation Duration="0:0:0.15" Easing="CubicEaseOut" FillMode="Forward">
                <KeyFrame Cue="100%">
                    <Setter Property="ScaleTransform.ScaleX" Value="1" />
                    <Setter Property="ScaleTransform.ScaleY" Value="1" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Hover Lift (subtle elevation) -->
    <Style Selector="Border.HoverLift:pointerover">
        <Style.Animations>
            <Animation Duration="0:0:0.15" Easing="CubicEaseOut" FillMode="Forward">
                <KeyFrame Cue="100%">
                    <Setter Property="TranslateTransform.Y" Value="-2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Border.HoverLift:not(:pointerover)">
        <Style.Animations>
            <Animation Duration="0:0:0.15" Easing="CubicEaseOut" FillMode="Forward">
                <KeyFrame Cue="100%">
                    <Setter Property="TranslateTransform.Y" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

</Styles>
