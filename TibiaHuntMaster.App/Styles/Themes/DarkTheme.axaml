<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================ -->
    <!-- DARK THEME - TibiaHuntMaster Design System -->
    <!-- ============================================ -->

    <!-- Background Colors -->
    <Color x:Key="ColorBackground">#121212</Color>
    <Color x:Key="ColorSurface">#1e1e1e</Color>
    <Color x:Key="ColorSurfaceElevated">#252526</Color>
    <Color x:Key="ColorSurfaceHover">#2a2a2a</Color>

    <!-- Border Colors -->
    <Color x:Key="ColorBorder">#333333</Color>
    <Color x:Key="ColorBorderHover">#555555</Color>
    <Color x:Key="ColorBorderLight">#444444</Color>

    <!-- Text Colors -->
    <Color x:Key="ColorTextPrimary">#FFFFFF</Color>
    <Color x:Key="ColorTextSecondary">#AAAAAA</Color>
    <Color x:Key="ColorTextTertiary">#888888</Color>
    <Color x:Key="ColorTextDisabled">#666666</Color>
    <Color x:Key="ColorTextMuted">#555555</Color>

    <!-- Accent Colors (Theme Independent) -->
    <Color x:Key="ColorAccentGold">#D4AF37</Color>
    <Color x:Key="ColorAccentBlue">#2196F3</Color>
    <Color x:Key="ColorAccentGreen">#4CAF50</Color>
    <Color x:Key="ColorAccentRed">#FF5555</Color>
    <Color x:Key="ColorAccentPurple">#AB47BC</Color>
    <Color x:Key="ColorAccentOrange">#FFC107</Color>

    <!-- Semantic Colors -->
    <Color x:Key="ColorSuccess">#4CAF50</Color>
    <Color x:Key="ColorWarning">#FFD700</Color>
    <Color x:Key="ColorError">#FF5555</Color>
    <Color x:Key="ColorInfo">#2196F3</Color>

    <!-- Transparency Colors -->
    <Color x:Key="ColorOverlay">#80000000</Color>

    <!-- ============================================ -->
    <!-- SOLID COLOR BRUSHES -->
    <!-- ============================================ -->

    <!-- Background Brushes -->
    <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource ColorBackground}" />
    <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="BrushSurfaceElevated" Color="{StaticResource ColorSurfaceElevated}" />
    <SolidColorBrush x:Key="BrushSurfaceHover" Color="{StaticResource ColorSurfaceHover}" />

    <!-- Border Brushes -->
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="BrushBorderHover" Color="{StaticResource ColorBorderHover}" />
    <SolidColorBrush x:Key="BrushBorderLight" Color="{StaticResource ColorBorderLight}" />

    <!-- Text Brushes -->
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="BrushTextTertiary" Color="{StaticResource ColorTextTertiary}" />
    <SolidColorBrush x:Key="BrushTextDisabled" Color="{StaticResource ColorTextDisabled}" />
    <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource ColorTextMuted}" />

    <!-- Accent Brushes -->
    <SolidColorBrush x:Key="BrushAccentGold" Color="{StaticResource ColorAccentGold}" />
    <SolidColorBrush x:Key="BrushAccentBlue" Color="{StaticResource ColorAccentBlue}" />
    <SolidColorBrush x:Key="BrushAccentGreen" Color="{StaticResource ColorAccentGreen}" />
    <SolidColorBrush x:Key="BrushAccentRed" Color="{StaticResource ColorAccentRed}" />
    <SolidColorBrush x:Key="BrushAccentPurple" Color="{StaticResource ColorAccentPurple}" />
    <SolidColorBrush x:Key="BrushAccentOrange" Color="{StaticResource ColorAccentOrange}" />

    <!-- Semantic Brushes -->
    <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource ColorSuccess}" />
    <SolidColorBrush x:Key="BrushWarning" Color="{StaticResource ColorWarning}" />
    <SolidColorBrush x:Key="BrushError" Color="{StaticResource ColorError}" />
    <SolidColorBrush x:Key="BrushInfo" Color="{StaticResource ColorInfo}" />

    <!-- Transparency Brushes -->
    <SolidColorBrush x:Key="BrushOverlay" Color="{StaticResource ColorOverlay}" />

</ResourceDictionary>
