<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="using:TibiaHuntMaster.App.Components"
             x:Class="TibiaHuntMaster.App.Components.EmptyState"
             x:DataType="components:EmptyState"
             x:CompileBindings="False">

    <!-- Empty State Component -->
    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="{StaticResource SpacingMD}"
                Margin="{StaticResource PaddingXL}"
                Classes="FadeIn">

        <!-- Icon (optional, can be overridden) -->
        <TextBlock Text="{Binding Icon}"
                   FontSize="48"
                   HorizontalAlignment="Center"
                   Opacity="0.5" />

        <!-- Message Text -->
        <TextBlock Text="{Binding Message}"
                   FontSize="{StaticResource FontSizeBody}"
                   Foreground="{StaticResource BrushTextMuted}"
                   FontStyle="Italic"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   MaxWidth="300" />

    </StackPanel>

</UserControl>
